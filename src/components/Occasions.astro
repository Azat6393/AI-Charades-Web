---
import type { Dictionary } from "../i18n/types";

interface Props {
  dict: Dictionary;
}
const { dict } = Astro.props;
const tints = ["--fiesta-peach", "--fiesta-mint", "--fiesta-lavender", "--fiesta-sky"];
---

<section class="section section--surface scallop-top reveal" style="--scallop: var(--fiesta-bg)">
  <div class="container">
    <h2 class="center">{dict.occasions.h2}</h2>
    <p class="center intro">
      {dict.occasions.intro}
    </p>
    <ul class="tiles reveal-stagger">
      {dict.occasions.tiles.map((t, i) => (
        <li class="card card--lift tile" style={`background: var(${tints[i % tints.length]})`}>
          <span class="tile-icon" aria-hidden="true">{t.icon}</span>
          <span>{t.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .center { text-align: center; }
  .intro { max-width: 60ch; margin: 0 auto 2rem; color: var(--ink-muted); }
  .tiles {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(2, 1fr);
  }
  .tile {
    padding: 1.75rem 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-weight: 700;
    text-align: center;
  }
  .tile:nth-child(odd) { rotate: -1deg; }
  .tile:nth-child(even) { rotate: 1deg; }
  .tile:hover { rotate: 0deg; }
  .tile-icon {
    font-size: 2.25rem;
    transition: scale 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .tile:hover .tile-icon { scale: 1.2; }
  @media (min-width: 700px) {
    .tiles { grid-template-columns: repeat(4, 1fr); }
  }
</style>
