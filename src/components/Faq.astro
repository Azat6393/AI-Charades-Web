---
import type { Dictionary } from "../i18n/types";

interface Props {
  dict: Dictionary;
}
const { dict } = Astro.props;
---

<section id="faq" class="section reveal">
  <div class="container narrow">
    <h2 class="center">{dict.faqSection.h2}</h2>
    <div class="accordion">
      {dict.faq.map((item, i) => (
        <div class="item card">
          <h3>
            <button
              class="trigger"
              aria-expanded="false"
              aria-controls={`faq-panel-${i}`}
              id={`faq-trigger-${i}`}
            >
              <span>{item.q}</span>
              <span class="chevron" aria-hidden="true">+</span>
            </button>
          </h3>
          <div
            class="panel"
            id={`faq-panel-${i}`}
            role="region"
            aria-labelledby={`faq-trigger-${i}`}
            hidden
          >
            <p>{item.a}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .center { text-align: center; margin-bottom: 2rem; }
  .narrow { max-width: 780px; }
  .accordion { display: grid; gap: 1rem; }
  .item {
    overflow: hidden;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  }
  .item:has(.trigger[aria-expanded="true"]) {
    background: var(--fiesta-surface);
    transform: rotate(-0.4deg);
  }
  .item h3 { margin: 0; font-size: 1rem; }
  .trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: none;
    border: none;
    padding: 1.25rem 1.5rem;
    font: inherit;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--fiesta-ink);
    text-align: start;
    cursor: pointer;
  }
  .trigger:hover .chevron {
    background: var(--fiesta-primary);
  }
  .trigger:focus-visible {
    outline: 3px solid var(--fiesta-accent);
    outline-offset: -3px;
    border-radius: var(--radius-md);
  }
  .chevron {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    border: 2px solid var(--fiesta-ink);
    font-size: 1.1rem;
    line-height: 1;
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.2s;
  }
  .trigger[aria-expanded="true"] .chevron {
    transform: rotate(45deg);
    background: var(--fiesta-primary);
  }
  .panel { padding: 0 1.5rem 1.25rem; }
  .panel p { margin: 0; color: var(--ink-muted); }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".trigger").forEach((btn) => {
    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", String(!expanded));
      const panel = document.getElementById(btn.getAttribute("aria-controls")!);
      if (panel) panel.hidden = expanded;
    });
  });
</script>
