---
interface Props {
  class?: string;
  mood?: "happy" | "wink";
}
const { class: className = "", mood = "happy" } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 200 200"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Fiesta, the AI Charades mascot"
>
  <ellipse cx="104" cy="178" rx="52" ry="7" fill="rgba(26,20,16,0.15)" />
  <path
    d="M40 92 Q36 44 84 28 Q136 16 168 52 Q188 84 172 124 Q164 164 116 176 Q64 184 44 144 Q28 120 40 92 Z"
    fill="#FFD43B"
    stroke="#1A1410"
    stroke-width="6"
    stroke-linejoin="round"
  />
  <ellipse cx="64" cy="56" rx="16" ry="10" fill="rgba(255,255,255,0.45)" transform="rotate(-20 64 56)" />
  <circle cx="82" cy="96" r="9" fill="#1A1410" />
  <circle cx="138" cy="96" r="9" fill="#1A1410" />
  <circle cx="66" cy="118" r="10" fill="#FF7EB3" opacity="0.55" />
  <circle cx="152" cy="118" r="10" fill="#FF7EB3" opacity="0.55" />
  {mood === "happy" ? (
    <path d="M72 128 Q104 156 136 128" stroke="#1A1410" stroke-width="6" stroke-linecap="round" fill="none" />
  ) : (
    <path d="M72 130 Q104 150 136 122" stroke="#1A1410" stroke-width="6" stroke-linecap="round" fill="none" />
  )}
  <path d="M100 26 Q94 12 104 6" stroke="#1A1410" stroke-width="6" stroke-linecap="round" fill="none" />
</svg>
