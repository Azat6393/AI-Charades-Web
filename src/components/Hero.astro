---
import StoreBadges from "./StoreBadges.astro";
import Mascot from "./Mascot.astro";
import { Image } from "astro:assets";
import homeScreenshot from "../assets/screenshots/home.png";
import soloGuessScreenshot from "../assets/screenshots/ai-solo-guess.png";
import type { Dictionary } from "../i18n/types";

interface Props {
  dict: Dictionary;
}
const { dict } = Astro.props;
---

<section class="hero">
  <div class="hero-confetti" aria-hidden="true">
    <svg class="deco deco-star" viewBox="0 0 40 40" fill="none"><path d="M20 2 L24 15 L38 16 L26 24 L30 38 L20 29 L10 38 L14 24 L2 16 L16 15 Z" fill="var(--fiesta-primary)" stroke="var(--fiesta-ink)" stroke-width="2.5" stroke-linejoin="round"/></svg>
    <svg class="deco deco-squiggle" viewBox="0 0 72 20" fill="none"><path d="M2 14 Q11 2 20 12 Q29 22 38 10 Q47 -2 56 10 Q62 18 70 8" stroke="var(--fiesta-blue)" stroke-width="4.5" stroke-linecap="round"/></svg>
    <svg class="deco deco-plus" viewBox="0 0 26 26" fill="none"><path d="M13 3 V23 M3 13 H23" stroke="var(--fiesta-accent)" stroke-width="5" stroke-linecap="round"/></svg>
    <svg class="deco deco-dot" viewBox="0 0 18 18"><circle cx="9" cy="9" r="7" fill="var(--fiesta-pink)" stroke="var(--fiesta-ink)" stroke-width="2.5"/></svg>
    <svg class="deco deco-tri" viewBox="0 0 30 28" fill="none"><path d="M15 3 L27 24 H3 Z" fill="var(--fiesta-green)" stroke="var(--fiesta-ink)" stroke-width="2.5" stroke-linejoin="round"/></svg>
  </div>
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">{dict.hero.eyebrow}</p>
      <h1>{dict.hero.h1}</h1>
      <p class="subhead">
        {dict.hero.subhead}
      </p>
      <StoreBadges dict={dict} size="lg" />
      <p class="micro">{dict.hero.micro}</p>
    </div>
    <div class="hero-visual" aria-hidden="false">
      <div class="blob" aria-hidden="true"></div>
      <div class="phone-frame phone-frame--back">
        <Image
          src={soloGuessScreenshot}
          alt={dict.hero.imageAlt2}
          width={320}
          fetchpriority="high"
        />
      </div>
      <div class="phone-frame phone-frame--front">
        <Image
          src={homeScreenshot}
          alt={dict.hero.imageAlt}
          width={320}
          fetchpriority="high"
        />
      </div>
      <Mascot class="hero-mascot" />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: clamp(3rem, 7vw, 5rem);
    padding-bottom: calc(var(--section-pad) + 1rem);
    overflow: hidden;
  }
  .hero-confetti {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .deco {
    position: absolute;
    animation: float 5s ease-in-out infinite;
  }
  .deco-star { width: 44px; inset-inline-start: 6%; top: 12%; animation-delay: 0s; }
  .deco-squiggle { width: 76px; inset-inline-end: 8%; top: 10%; animation-delay: -1.4s; }
  .deco-plus { width: 26px; inset-inline-start: 42%; top: 6%; animation-delay: -2.6s; }
  .deco-dot { width: 18px; inset-inline-start: 3%; bottom: 18%; animation-delay: -3.4s; }
  .deco-tri { width: 30px; inset-inline-end: 4%; bottom: 24%; animation-delay: -1.9s; rotate: 12deg; }
  @media (max-width: 899px) {
    .deco-star, .deco-squiggle, .deco-plus { display: none; }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-14px) rotate(6deg); }
  }

  .hero-grid {
    display: grid;
    gap: clamp(2.5rem, 6vw, 4rem);
    align-items: center;
  }
  .hero-copy > * {
    animation: rise-in 0.7s cubic-bezier(0.22, 1, 0.36, 1) backwards;
  }
  .hero-copy > :nth-child(1) { animation-delay: 0.05s; }
  .hero-copy > :nth-child(2) { animation-delay: 0.15s; }
  .hero-copy > :nth-child(3) { animation-delay: 0.25s; }
  .hero-copy > :nth-child(4) { animation-delay: 0.35s; }
  .hero-copy > :nth-child(5) { animation-delay: 0.45s; }

  @keyframes rise-in {
    from { opacity: 0; transform: translateY(22px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .subhead {
    font-size: 1.1875rem;
    color: var(--ink-muted);
    max-width: 46ch;
  }
  .micro {
    margin-top: 0.6rem;
    font-size: 0.9375rem;
    color: var(--ink-muted);
    font-weight: 600;
  }
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    animation: rise-in 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.2s backwards;
  }
  .blob {
    position: absolute;
    width: min(420px, 100%);
    aspect-ratio: 1;
    top: 50%;
    left: 50%;
    translate: -50% -50%;
    background: var(--fiesta-primary);
    border-radius: 58% 42% 55% 45% / 48% 55% 45% 52%;
    opacity: 0.5;
    animation: blob-morph 12s ease-in-out infinite;
  }
  @keyframes blob-morph {
    0%, 100% { border-radius: 58% 42% 55% 45% / 48% 55% 45% 52%; }
    33% { border-radius: 45% 55% 48% 52% / 55% 45% 58% 42%; }
    66% { border-radius: 52% 48% 42% 58% / 45% 52% 48% 55%; }
  }
  .phone-frame {
    position: relative;
    max-width: min(240px, 42vw);
    border-radius: 36px;
    overflow: hidden;
    border: 4px solid var(--fiesta-ink);
    background: var(--fiesta-card);
    box-shadow: 12px 14px 0 rgba(26, 20, 16, 0.16);
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .phone-frame--front {
    z-index: 2;
    margin-inline-start: -12%;
    transform: rotate(-3deg) translateY(1.25rem);
  }
  .phone-frame--back {
    z-index: 1;
    transform: rotate(4deg) translateY(-0.75rem);
  }
  .phone-frame--front:hover {
    transform: rotate(-1deg) translateY(0.9rem);
  }
  .phone-frame--back:hover {
    transform: rotate(2deg) translateY(-1.1rem);
  }
  .phone-frame :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }
  :global(.hero-mascot) {
    position: absolute;
    width: 116px;
    bottom: -18px;
    inset-inline-end: -6px;
    transform: rotate(6deg);
    animation: mascot-bob 3.2s ease-in-out infinite;
  }
  @keyframes mascot-bob {
    0%, 100% { translate: 0 0; }
    50% { translate: 0 -10px; }
  }
  @media (min-width: 900px) {
    .hero-grid {
      grid-template-columns: 1.1fr 0.9fr;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-copy > *, .hero-visual { animation: none; }
  }
</style>
