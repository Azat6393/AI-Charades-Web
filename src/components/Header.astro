---
import { Image } from "astro:assets";
import { site } from "../data/site";
import logo from "../assets/brand/logo.png";
import { localePath } from "../i18n";
import type { Dictionary } from "../i18n/types";

interface Props {
  dict: Dictionary;
  lang: string;
}
const { dict, lang } = Astro.props;
const home = localePath(lang, "/");
---

<header class="site-header">
  <div class="container bar">
    <a href={home} class="logo">
      <Image src={logo} alt="" width={36} height={36} class="logo-mark" />
      {site.name}
    </a>
    <nav class="nav" aria-label="Primary">
      <a href={`${home}#modes`}>{dict.header.modes}</a>
      <a href={`${home}#packs`}>{dict.header.packs}</a>
      <a href={`${home}#faq`}>{dict.header.faq}</a>
      {dict.header.guides && <a href="/guides/">{dict.header.guides}</a>}
    </nav>
    <a href={`${home}#final-cta`} class="btn-primary get-app">{dict.header.getApp}</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(245, 233, 201, 0.85);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    border-bottom: 2px solid var(--hairline);
  }
  .logo:hover .logo-mark {
    rotate: -8deg;
    scale: 1.08;
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.9rem;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    text-decoration: none;
    color: var(--fiesta-ink);
  }
  .logo-mark {
    border-radius: 9px;
    width: 36px;
    height: 36px;
    transition: rotate 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), scale 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .nav {
    display: none;
    gap: 1.75rem;
    font-weight: 600;
  }
  .nav a {
    text-decoration: none;
    position: relative;
  }
  .nav a::after {
    content: "";
    position: absolute;
    inset-inline: 0;
    bottom: -6px;
    height: 3px;
    border-radius: 3px;
    background: var(--fiesta-accent);
    scale: 0 1;
    transition: scale 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .nav a:hover { color: var(--fiesta-accent); }
  .nav a:hover::after { scale: 1 1; }
  .get-app {
    padding: 0.65rem 1.2rem;
    font-size: 0.9375rem;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  @media (min-width: 720px) {
    .nav { display: flex; }
  }
</style>
