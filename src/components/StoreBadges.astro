---
import { site } from "../data/site";
import type { Dictionary } from "../i18n/types";

interface Props {
  dict: Dictionary;
  size?: "lg" | "md";
}
const { dict, size = "md" } = Astro.props;
const height = size === "lg" ? "56" : "44";
---

<div class:list={["store-badges", size]}>
  <a
    href={site.appStoreUrl}
    aria-label={dict.storeBadges.appStoreAria}
    rel="noopener"
  >
    <img
      src="/badges/app-store-badge.svg"
      alt=""
      height={height}
      width={size === "lg" ? "168" : "132"}
      loading="lazy"
    />
  </a>
  <a
    href={site.playStoreUrl}
    aria-label={dict.storeBadges.playStoreAria}
    rel="noopener"
  >
    <img
      src="/badges/google-play-badge.png"
      alt=""
      height={height}
      width={size === "lg" ? "189" : "148"}
      loading="lazy"
    />
  </a>
</div>

<style>
  .store-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }
  .store-badges img {
    height: 44px;
    width: auto;
    border-radius: 8px;
  }
  .store-badges.lg img {
    height: 56px;
  }
  .store-badges a {
    transition: transform 0.12s;
    line-height: 0;
  }
  .store-badges a:hover {
    transform: translateY(2px);
  }
  .store-badges a:focus-visible {
    outline: 3px solid var(--fiesta-ink);
    outline-offset: 3px;
    border-radius: 8px;
  }
</style>
