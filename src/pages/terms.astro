---
import LegalLayout from "../layouts/LegalLayout.astro";
import { getLegalDictionary, tpl } from "../i18n";

const lang = "en";
const legal = getLegalDictionary(lang).terms;
---

<LegalLayout
  title={legal.metaTitle}
  description={legal.metaDescription}
  path="/terms"
  lang={lang}
>
  <h1>{legal.h1}</h1>
  <p><strong>{legal.lastUpdatedLabel}</strong> {legal.dateValue}</p>

  <p set:html={tpl(legal.intro, lang)} />

  {legal.sections.map((section) => (
    <Fragment>
      <h2>{section.h2}</h2>
      {section.body.map((block) => <Fragment set:html={tpl(block, lang)} />)}
    </Fragment>
  ))}
</LegalLayout>
