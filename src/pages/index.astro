---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import TrustStrip from "../components/TrustStrip.astro";
import ModeSolo from "../components/ModeSolo.astro";
import ModeParty from "../components/ModeParty.astro";
import HowItWorks from "../components/HowItWorks.astro";
import PackGrid from "../components/PackGrid.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import Occasions from "../components/Occasions.astro";
import GuidesTeaser from "../components/GuidesTeaser.astro";
import Faq from "../components/Faq.astro";
import FinalCta from "../components/FinalCta.astro";
import Footer from "../components/Footer.astro";
import { defaultLocale, getDictionary } from "../i18n";

const lang = defaultLocale;
const dict = getDictionary(lang);
---

<BaseLayout
  title={dict.meta.title}
  description={dict.meta.description}
  path="/"
  lang={lang}
  dict={dict}
>
  <Header dict={dict} lang={lang} />
  <main>
    <Hero dict={dict} />
    <TrustStrip dict={dict} />
    <ModeSolo dict={dict} />
    <ModeParty dict={dict} />
    <HowItWorks dict={dict} />
    <PackGrid dict={dict} />
    <FeatureGrid dict={dict} />
    <Occasions dict={dict} />
    <GuidesTeaser />
    <Faq dict={dict} />
    <FinalCta dict={dict} />
  </main>
  <Footer dict={dict} lang={lang} />
</BaseLayout>
