---
import LegalLayout from "../../layouts/LegalLayout.astro";
import { site } from "../../data/site";
import { localeCodes, getLegalDictionary, tpl } from "../../i18n";

export function getStaticPaths() {
  return localeCodes.filter((lang) => lang !== "en").map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const legal = getLegalDictionary(lang as string).terms;
---

<LegalLayout
  title={legal.metaTitle}
  description={legal.metaDescription}
  path={`/${lang}/terms`}
  lang={lang as string}
>
  <h1>{legal.h1}</h1>
  <p><strong>{legal.lastUpdatedLabel}</strong> {legal.dateValue}</p>

  <p set:html={tpl(legal.intro, lang as string)} />

  {legal.sections.map((section) => (
    <Fragment>
      <h2>{section.h2}</h2>
      {section.body.map((block) => <Fragment set:html={tpl(block, lang as string)} />)}
    </Fragment>
  ))}
</LegalLayout>
